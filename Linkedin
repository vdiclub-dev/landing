    // 3) TABLE CONSEILLEE : prospects(id, entreprise, ville, secteur, site_web, contact_nom,
    //    linkedin_url, notes, resume, besoin_detecte, message_connexion, message_1,
    //    relance_1, relance_2, statut, created_at)
    // =========================

    document.getElementById('prospectForm').addEventListener('submit', addProspectFromForm);
    loadProspects();
    renderAll();
  </script>
